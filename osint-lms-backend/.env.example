# Backend - OSINT LMS
# Variables d'environnement

# Port du serveur
PORT=3000

# JWT Secret (pour les tokens d'authentification)
JWT_SECRET=votre_secret_ultra_securise_ici_changez_moi

# Neon PostgreSQL Database URL
# Format: postgresql://user:password@host/database?sslmode=require
DATABASE_URL=postgresql://your_user:your_password@ep-xxx-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Environnement
NODE_ENV=production
